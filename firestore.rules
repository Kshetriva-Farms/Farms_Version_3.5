rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 1. Allow anyone to submit leads (create only), but restrict reading/modifying to logged-in admins
    match /leads/{leadId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    // 2. Allow anyone to read the product catalog, but restrict writes to logged-in admins
    match /products/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // 3. Allow anyone to read manual window override state, but restrict writes to logged-in admins
    match /metadata/orderingWindow {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // 4. Allow anyone to write window logs (for audit), but restrict reading/deleting to logged-in admins
    match /window_logs/{logId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null;
    }
    
    // 5. Allow anyone to read orders (for client order tracking), but restrict writes to logged-in admins
    match /orders/{orderId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
  }
}
